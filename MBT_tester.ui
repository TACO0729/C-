												<property name="minimumSize">
													<size>
														<width>150</width>
														<height>50</height>
													</size>
												</property>
											</widget>
										</item>
										<item>
											<spacer name="horizontalSpacer_2">
												<property name="orientation">
													<enum>Qt::Horizontal</enum>
												</property>
											</spacer>
										</item>
									</layout>
								</item>
								<item>
									<spacer name="verticalSpacer_3">
										<property name="orientation">
											<enum>Qt::Vertical</enum>
										</property>
									</spacer>
