<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
	<class>MBT_tester</class>
	<widget class="QMainWindow" name="MBT_tester">
		<property name="geometry">
			<rect>
				<x>0</x>
				<y>0</y>
				<width>750</width>
				<height>600</height>
			</rect>
		</property>
		<property name="windowTitle">
			<string>MBTI 人格测试</string>
		</property>
		<widget class="QWidget" name="centralwidget">
			<layout class="QVBoxLayout" name="verticalLayout">
				<item>
