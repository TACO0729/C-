<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
	<class>ResultPage</class>
	<widget class="QWidget" name="ResultPage">
		<property name="geometry">
			<rect>
				<x>0</x>
				<y>0</y>
				<width>980</width>
				<height>620</height>
			</rect>
		</property>
		<property name="windowTitle">
			<string>MBTI测试结果</string>
		</property>
		<property name="styleSheet">
			<string notr="true">
				QWidget#ResultPage {
				background-color: #ffffff;
				font-family: "YouYuan", "幼圆", "Microsoft YaHei", "微软雅黑", "SimHei", "黑体";
				}

				QLabel {
				background-color: transparent;
				font-family: "YouYuan", "幼圆", "Microsoft YaHei", "微软雅黑", "SimHei", "黑体";
				}

				QFrame#resultCard {
				background-color: #ffffff;
				border: 1px solid #eeeeee;
				border-top: 10px solid #80649f;
				border-radius: 8px;
				}

				QWidget#bottomButtonWidget {
				background-color: #ffffff;
				}
			</string>
		</property>

		<layout class="QVBoxLayout" name="mainLayout">
			<property name="spacing">
				<number>0</number>
			</property>
			<property name="leftMargin">
				<number>0</number>
			</property>
			<property name="topMargin">
				<number>0</number>
			</property>
			<property name="rightMargin">
				<number>0</number>
			</property>
			<property name="bottomMargin">
				<number>0</number>
			</property>

			<!-- 顶部标题区域 -->
			<item>
				<widget class="QWidget" name="headerWidget">
					<property name="minimumHeight">
						<number>130</number>
					</property>
					<property name="styleSheet">
						<string notr="true">
							QWidget#headerWidget {
							background-color: #ffffff;
							border-bottom: 1px solid #eeeeee;
							}
						</string>
					</property>
					<layout class="QVBoxLayout" name="headerLayout">
						<property name="spacing">
							<number>8</number>
						</property>
						<property name="leftMargin">
							<number>0</number>
						</property>
						<property name="topMargin">
							<number>25</number>
