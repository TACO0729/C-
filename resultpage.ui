								</property>
								<property name="styleSheet">
									<string notr="true">
										QPushButton {
										background-color: #7561a0;
										color: #ffffff;
										border: 3px solid #d4c8ea;
										border-radius: 12px;
										font-family: "YouYuan", "幼圆", "Microsoft YaHei", "微软雅黑", "SimHei", "黑体";
										font-weight: bold;
										}

										QPushButton:hover {
										background-color: #66548e;
										border: 3px solid #bba9dd;
										}

										QPushButton:pressed {
										background-color: #554578;
										padding-top: 3px;
										}
